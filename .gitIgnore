*.obj
*.mtl
*.fbx
*.dae
*.gltf
*.glb
*.png
*.jpg
*.tga
*.bmp

# Ignorar todos los archivos ZIP de modelos
ProyectoBimestral/model/**/*.zip

# Excepciones: permitir assets del proyecto
!ProyectoBimestral/model/**
